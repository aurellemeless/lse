# Reown (WalletConnect) — https://cloud.reown.com
NEXT_PUBLIC_REOWN_PROJECT_ID=your_project_id_here

# Sepolia RPC — Alchemy/Infura recommended to avoid public rate limits
# https://dashboard.alchemy.com or https://infura.io
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/your_key_here

# Contract addresses — fill after: npx hardhat ignition deploy ignition/modules/LSEDemo.ts --network sepolia
NEXT_PUBLIC_LSE_ADDRESS=0x
NEXT_PUBLIC_WETH_ADDRESS=0x
NEXT_PUBLIC_ZYFAI_ADDRESS=0x
NEXT_PUBLIC_SWAPPER_ADDRESS=0x
